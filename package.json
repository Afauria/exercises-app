{
  "name": "exam-app",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "tsx scripts/build-bank-json.ts",
    "build": "vite build && node scripts/copy-gh-spa-fallback.mjs",
    "dev": "tsx scripts/build-bank-json.ts && vite",
    "preview": "vite preview",
    "preview:test": "vite preview --port 5174 --strictPort --host 127.0.0.1",
    "test:e2e": "playwright test",
    "verify": "tsc -p tsconfig.app.json --noEmit && npx playwright install chromium && npm run build && playwright test"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.5.0",
    "tsx": "^4.19.3",
    "typescript": "~5.9.2",
    "vite": "^6.3.0"
  }
}
